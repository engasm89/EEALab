// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  logoUrl           String?
  plan              String   @default("FREE")
  billingCustomerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  memberships       Membership[]
  labs              Lab[]
  labRuns           LabRun[]
  publishRequests   PublishRequest[]
  plans             Plan[]
  subscriptions     Subscription[]
  usageCounters     UsageCounter[]
  feedback          Feedback[]

  @@map("organizations")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String?
  locale         String   @default("en")
  avatarUrl      String?
  activeOrgId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  memberships     Membership[]
  createdLabs     Lab[]        @relation("LabCreator")
  labRuns         LabRun[]
  publishRequests PublishRequest[]
  suggestions     Suggestion[]
  reviewedRequests PublishRequest[] @relation("PublishRequestReviewer")
  feedback        Feedback[]

  momentumProfile              MomentumProfile?
  momentumSubscriptions        MomentumSubscription[]
  momentumLessonProgresses     MomentumLessonProgress[]
  momentumUserProjects         MomentumUserProject[]
  momentumDailyRituals         MomentumDailyRitual[]
  momentumWeeklyReviews        MomentumWeeklyReview[]
  momentumCommunityPosts       MomentumCommunityPost[]
  momentumCommunityComments    MomentumCommunityComment[]
  momentumStaffGrant           MomentumStaffGrant?

  @@map("users")
}

model Membership {
  id     String @id @default(cuid())
  orgId  String
  userId String
  role   Role   @default(STUDENT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("memberships")
}

model Lab {
  id                     String           @id @default(cuid())
  orgId                  String?          // null = global/public lab
  title                  String
  slug                   String           @unique
  category               LabCategory
  educationLevels        String[]
  standards              String[]
  type                   LabType
  description            String
  thumbnailUrl           String?
  tags                   String[]
  visibility             LabVisibility    @default(PUBLIC)
  simulationManifestUrl  String
  codeTemplates          Json?
  createdByUserId        String
  verified               Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  // Relations
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("LabCreator", fields: [createdByUserId], references: [id])
  labRuns      LabRun[]

  @@map("labs")
}

model LabRun {
  id                    String      @id @default(cuid())
  orgId                 String
  labId                 String
  userId                String
  mode                  RunMode
  status                RunStatus   @default(ACTIVE)
  startedAt             DateTime    @default(now())
  endedAt               DateTime?
  runSeconds            Int         @default(0)
  fastBuildSecondsUsed  Int         @default(0)
  events                Json?

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lab          Lab          @relation(fields: [labId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lab_runs")
}

model PublishRequest {
  id                String                @id @default(cuid())
  orgId             String?               // optional for global submissions
  submittedByUserId String
  title             String
  description       String
  category          LabCategory
  educationLevels   String[]
  standards         String[]
  manifestUploadUrl String
  status            PublishRequestStatus  @default(PENDING)
  reviewerUserId    String?
  createdAt         DateTime              @default(now())
  reviewedAt        DateTime?

  // Relations
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  submittedBy  User          @relation(fields: [submittedByUserId], references: [id])
  reviewer     User?         @relation("PublishRequestReviewer", fields: [reviewerUserId], references: [id])

  @@map("publish_requests")
}

model Suggestion {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("suggestions")
}

model Plan {
  id                      String @id @default(cuid())
  orgId                   String
  name                    String
  tier                    PlanTier
  seatLimit               Int
  ultraconcurrentLimit    Int
  realtimeConcurrencyLimit Int
  fastBuildMinutes        Int
  priceId                 String? // Stripe price ID

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("plans")
}

model Subscription {
  id                 String            @id @default(cuid())
  orgId              String
  stripeCustomerId   String
  stripeSubId        String
  planId             String
  status             SubscriptionStatus
  currentPeriodEnd   DateTime

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageCounter {
  id               String @id @default(cuid())
  orgId            String
  month            String // YYYY-MM format
  fastBuildSeconds Int    @default(0)
  realtimeSessions Int    @default(0)

  // Relations
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month])
  @@map("usage_counters")
}

model Webinar {
  id       String          @id @default(cuid())
  title    String
  startsAt DateTime
  url      String
  audience WebinarAudience
  locale   String          @default("en")

  @@map("webinars")
}

model HelpArticle {
  id        String          @id @default(cuid())
  slug      String          @unique
  title     String
  contentMD String
  audience  WebinarAudience
  locale    String          @default("en")

  @@map("help_articles")
}

model Feedback {
  id      String  @id @default(cuid())
  userId  String?
  orgId   String?
  score   Int     // 0-100 scale
  path    String
  comment String?
  createdAt DateTime @default(now())

  // Relations
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@map("feedback")
}

// Enums
enum Role {
  OWNER
  ADMIN
  TEACHER
  STUDENT
}

enum LabCategory {
  BIOLOGY
  CHEMISTRY
  ELECTRONICS
  ENGINEERING
  PHYSICS
  ROBOTICS
}

enum LabType {
  ULTRACONCURRENT
  REALTIME
  SANDBOX
}

enum LabVisibility {
  PUBLIC
  ORG
  PRIVATE
}

enum RunMode {
  SANDBOX
  REALTIME
}

enum RunStatus {
  ACTIVE
  ENDED
}

enum PublishRequestStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

enum PlanTier {
  FREE
  HOBBY
  PRO
  CLASSROOM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
}

enum WebinarAudience {
  SCHOOLS
  HIGHER_ED
  ALL
}

// --- Kaizen Momentum (B2C learner SaaS; separate from org-scoped VirtualLabs billing) ---

enum MomentumPlanTier {
  FREE
  PRO
}

enum MomentumSubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  TRIALING
}

enum MomentumLessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MomentumUserProjectStatus {
  ACTIVE
  COMPLETED
}

enum MomentumSubmissionStatus {
  DRAFT
  SUBMITTED
}

enum MomentumCommunityPostStatus {
  PUBLISHED
  HIDDEN
}

enum MomentumStaffRole {
  ADMIN
  MENTOR
}

model MomentumProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  timezone         String    @default("UTC")
  weeklyHours      Int?
  focusTrack       String?
  onboardingDoneAt DateTime?
  preferences      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("momentum_profiles")
}

model MomentumBillingPlan {
  id                 String           @id @default(cuid())
  name               String
  tier               MomentumPlanTier
  stripePriceId      String?
  monthlyAmountCents Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  subscriptions MomentumSubscription[]

  @@map("momentum_billing_plans")
}

model MomentumSubscription {
  id                   String                     @id @default(cuid())
  userId               String
  planId               String
  stripeCustomerId     String
  stripeSubscriptionId String                     @unique
  status               MomentumSubscriptionStatus
  currentPeriodEnd     DateTime
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  user User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MomentumBillingPlan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@map("momentum_subscriptions")
}

model MomentumTrack {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String    @default("")
  level       String    @default("beginner")
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  modules           MomentumModule[]
  projectTemplates  MomentumProjectTemplate[]

  @@map("momentum_tracks")
}

model MomentumModule {
  id        String   @id @default(cuid())
  trackId   String
  sortOrder Int      @default(0)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  track   MomentumTrack   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  lessons MomentumLesson[]

  @@index([trackId])
  @@map("momentum_modules")
}

model MomentumLesson {
  id         String   @id @default(cuid())
  moduleId   String
  slug       String
  sortOrder  Int      @default(0)
  title      String
  type       String   @default("article")
  contentMd  String   @default("")
  estMinutes Int      @default(15)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  module     MomentumModule         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses MomentumLessonProgress[]

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("momentum_lessons")
}

model MomentumLessonProgress {
  id           String                       @id @default(cuid())
  userId       String
  lessonId     String
  status       MomentumLessonProgressStatus @default(NOT_STARTED)
  lastPosition Int                          @default(0)
  completedAt  DateTime?
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson MomentumLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("momentum_lesson_progress")
}

model MomentumProjectTemplate {
  id              String   @id @default(cuid())
  trackId         String?
  title           String
  description     String   @default("")
  estimatedHours  Int?
  templateKey     String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  track       MomentumTrack?                    @relation(fields: [trackId], references: [id], onDelete: SetNull)
  milestones  MomentumProjectTemplateMilestone[]
  userProjects MomentumUserProject[]

  @@map("momentum_project_templates")
}

model MomentumProjectTemplateMilestone {
  id          String   @id @default(cuid())
  templateId  String
  sortOrder   Int      @default(0)
  title       String
  description String   @default("")

  template MomentumProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("momentum_project_template_milestones")
}

model MomentumUserProject {
  id          String                   @id @default(cuid())
  userId      String
  templateId  String
  status      MomentumUserProjectStatus @default(ACTIVE)
  startedAt   DateTime                 @default(now())
  completedAt DateTime?

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     MomentumProjectTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissions  MomentumProjectSubmission[]
  completions  MomentumMilestoneCompletion[]

  @@index([userId])
  @@map("momentum_user_projects")
}

model MomentumMilestoneCompletion {
  id                  String   @id @default(cuid())
  userProjectId       String
  templateMilestoneId String
  completedAt         DateTime @default(now())

  userProject MomentumUserProject @relation(fields: [userProjectId], references: [id], onDelete: Cascade)

  @@unique([userProjectId, templateMilestoneId])
  @@map("momentum_milestone_completions")
}

model MomentumProjectSubmission {
  id                  String                   @id @default(cuid())
  userProjectId       String
  templateMilestoneId String?
  body                String?
  url                 String?
  status              MomentumSubmissionStatus @default(SUBMITTED)
  createdAt           DateTime                 @default(now())

  userProject MomentumUserProject @relation(fields: [userProjectId], references: [id], onDelete: Cascade)

  @@index([userProjectId])
  @@map("momentum_project_submissions")
}

model MomentumDailyRitual {
  id              String    @id @default(cuid())
  userId          String
  day             DateTime  @db.Date
  brainDump       String    @default("")
  highlightText   String    @default("")
  microCommitment String    @default("")
  energy          Int?
  mode            String    @default("normal")
  completedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId])
  @@map("momentum_daily_rituals")
}

model MomentumWeeklyReview {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime @db.Date
  responsesJson   Json
  commitmentsJson Json
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("momentum_weekly_reviews")
}

model MomentumCommunityPost {
  id        String                      @id @default(cuid())
  authorId  String
  category  String
  title     String
  body      String
  status    MomentumCommunityPostStatus @default(PUBLISHED)
  createdAt DateTime                  @default(now())

  author   User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments MomentumCommunityComment[]

  @@index([authorId])
  @@map("momentum_community_posts")
}

model MomentumCommunityComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   MomentumCommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("momentum_community_comments")
}

model MomentumStaffGrant {
  id     String            @id @default(cuid())
  userId String            @unique
  role   MomentumStaffRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("momentum_staff_grants")
}
