SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin sign-in and security
ADMIN_ALLOWED_EMAILS=admin@example.com
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_STORE=memory
REDIS_URL=
REDIS_TOKEN=

# Optional integrations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERT_WEBHOOK_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_UPLOAD_PIPELINE=true
ENABLE_DURABLE_RATELIMIT=false

# VirtualLabs (Prisma + Postgres — can be a Supabase Postgres connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
JWT_SECRET=generate_a_long_random_string

# Stripe (VirtualLabs billing; optional until you enable payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EDUCATOR_PRICE_ID=
STRIPE_INSTITUTION_PRICE_ID=

# C-Mastery / Vite (local: C-Mastery-The-Hacker-s-Journey/.env — on Vercel set in Project → Environment Variables)
# GEMINI_API_KEY=

# Do not commit real secret values.

